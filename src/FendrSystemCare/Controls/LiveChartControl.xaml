<UserControl x:Class="FendrSystemCare.Controls.LiveChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             SizeChanged="OnSizeChanged">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        <Canvas x:Name="ChartCanvas" Grid.Row="1" ClipToBounds="True" />
    </Grid>
</UserControl>
