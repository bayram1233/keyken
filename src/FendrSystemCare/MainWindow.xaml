<ui:FluentWindow
    x:Class="FendrSystemCare.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:tb="http://www.hardcodet.net/taskbar"
    xmlns:vm="clr-namespace:FendrSystemCare.ViewModels"
    Title="Fendr System Care"
    Width="1240" Height="800"
    MinWidth="960" MinHeight="640"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <ui:FluentWindow.InputBindings>
        <KeyBinding Modifiers="Control" Key="D1" Command="{Binding NavigateIndexCommand}" CommandParameter="1" />
        <KeyBinding Modifiers="Control" Key="D2" Command="{Binding NavigateIndexCommand}" CommandParameter="2" />
        <KeyBinding Modifiers="Control" Key="D3" Command="{Binding NavigateIndexCommand}" CommandParameter="3" />
        <KeyBinding Modifiers="Control" Key="D4" Command="{Binding NavigateIndexCommand}" CommandParameter="4" />
        <KeyBinding Modifiers="Control" Key="D5" Command="{Binding NavigateIndexCommand}" CommandParameter="5" />
        <KeyBinding Modifiers="Control" Key="D6" Command="{Binding NavigateIndexCommand}" CommandParameter="6" />
        <KeyBinding Modifiers="Control" Key="D7" Command="{Binding NavigateIndexCommand}" CommandParameter="7" />
        <KeyBinding Modifiers="Control" Key="D8" Command="{Binding NavigateIndexCommand}" CommandParameter="8" />
        <KeyBinding Modifiers="Control" Key="D9" Command="{Binding NavigateIndexCommand}" CommandParameter="9" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
    </ui:FluentWindow.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===================== TITLE BAR ===================== -->
        <ui:TitleBar Grid.Row="0" Title="Fendr System Care" />

        <!-- ===================== HEADER ===================== -->
        <Grid Grid.Row="1" Height="56" Margin="8,0,16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Collapse toggle + breadcrumb -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button x:Name="ToggleButton" Appearance="Transparent" Padding="8"
                           Icon="{ui:SymbolIcon Navigation24}" Click="OnToggleSidebar"
                           ToolTip="Toggle sidebar" />
                <TextBlock Text="Fendr" FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ui:SymbolIcon Symbol="ChevronRight24" FontSize="12" Margin="6,0,6,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                <TextBlock Text="{Binding CurrentPage.Title, FallbackValue=Dashboard}"
                           FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            </StackPanel>

            <!-- Global search -->
            <ui:TextBox x:Name="SearchBox" Grid.Column="1"
                        MaxWidth="420" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Icon="{ui:SymbolIcon Search24}"
                        PlaceholderText="Search modules (Ctrl+F)"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Quick actions -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button Appearance="Transparent" Padding="8" Margin="4,0,0,0"
                           Icon="{ui:SymbolIcon Alert24}" ToolTip="Notifications" />
                <ui:Button Appearance="Transparent" Padding="8" Margin="4,0,0,0"
                           Icon="{ui:SymbolIcon WeatherMoon24}" Command="{Binding ToggleThemeCommand}"
                           ToolTip="Switch light / dark theme" />
                <ui:Button Appearance="Transparent" Padding="8" Margin="4,0,0,0"
                           Icon="{ui:SymbolIcon Settings24}"
                           Command="{Binding NavigateIndexCommand}" CommandParameter="9"
                           ToolTip="Settings" />
            </StackPanel>
        </Grid>

        <!-- ===================== BODY ===================== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ===================== SIDEBAR ===================== -->
            <Border x:Name="Sidebar" Grid.Column="0" Width="248" Padding="12,4,12,12">
                <DockPanel>
                    <!-- Brand header -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,4,0,16">
                        <Border Width="40" Height="40" CornerRadius="10"
                                Background="{StaticResource AccentGradientBrush}">
                            <ui:SymbolIcon Symbol="ShieldCheckmark24" FontSize="22" Foreground="White" />
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Fendr" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="System Care" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Navigation list (grouped) -->
                    <ListBox
                        x:Name="NavList"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemsSource="{Binding NavigationView}"
                        SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource SectionHeader}"
                                                   Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=ListBox}, Converter={StaticResource BoolToVisibility}}" />
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListBox.GroupStyle>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="0,2" />
                                <Setter Property="Padding" Value="12,10" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Grid>
                                                <Border x:Name="Bd" CornerRadius="10" Padding="{TemplateBinding Padding}"
                                                        Background="Transparent">
                                                    <ContentPresenter />
                                                </Border>
                                                <!-- Active indicator stripe -->
                                                <Border x:Name="Indicator" Width="3" Height="20" CornerRadius="2"
                                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                                        Background="{StaticResource AccentGradientBrush}" Opacity="0" />
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                                    <Setter TargetName="Indicator" Property="Opacity" Value="1" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:NavigationItem}">
                                <StackPanel Orientation="Horizontal" ToolTip="{Binding Title}">
                                    <ui:SymbolIcon Symbol="{Binding Icon}" FontSize="18"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <TextBlock Text="{Binding Title}" Margin="14,0,0,0"
                                               Style="{StaticResource NavItemText}"
                                               Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=ListBox}, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ===================== CONTENT ===================== -->
            <Grid Grid.Column="1">
                <ContentControl
                    Content="{Binding CurrentPage}"
                    Margin="8,0,16,0"
                    Focusable="False" />

                <!-- Global busy overlay, shown while the active page is working. -->
                <Border Background="#66000000" CornerRadius="8" Margin="8,0,16,0"
                        Visibility="{Binding CurrentPage.IsBusy, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48" />
                        <TextBlock Margin="0,12,0,0" HorizontalAlignment="Center"
                                   Foreground="White" FontSize="13"
                                   Text="{Binding CurrentPage.StatusMessage}" />
                    </StackPanel>
                </Border>

                <!-- In-app notification bar (bottom, auto-dismissing). -->
                <ui:InfoBar
                    x:Name="Notification"
                    Margin="24"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Right"
                    MaxWidth="420"
                    IsClosable="True"
                    IsOpen="False" />
            </Grid>
        </Grid>

        <!-- ===================== STATUS BAR ===================== -->
        <Border Grid.Row="3" Height="30" Padding="16,0"
                Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <ui:SymbolIcon Symbol="Pulse24" FontSize="14" VerticalAlignment="Center"
                                   Foreground="{StaticResource SuccessBrush}" />
                    <TextBlock Text="{Binding CurrentPage.Title, StringFormat='Ready · {0}', FallbackValue=Ready}"
                               Margin="8,0,0,0" Style="{StaticResource StatusBarText}" />
                </StackPanel>
                <TextBlock HorizontalAlignment="Right" Style="{StaticResource StatusBarText}"
                           Text="{Binding AppVersion, StringFormat='Fendr System Care v{0}'}" />
            </Grid>
        </Border>

        <!-- System tray icon with a quick menu. -->
        <tb:TaskbarIcon
            x:Name="TrayIcon"
            ToolTipText="Fendr System Care"
            Visibility="Visible">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open" Click="OnTrayOpen" />
                    <Separator />
                    <MenuItem Header="Exit" Click="OnTrayExit" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</ui:FluentWindow>
