<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Theme-independent accent and status brushes. Surface/background colours
        come from the WPF-UI dynamic theme resources so light/dark just works.
    -->

    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#0A84FF" />
        <GradientStop Offset="1" Color="#5E5CE6" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HealthGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#30D158" />
        <GradientStop Offset="1" Color="#0A84FF" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="SuccessBrush" Color="#30D158" />
    <SolidColorBrush x:Key="WarningBrush" Color="#FF9F0A" />
    <SolidColorBrush x:Key="DangerBrush" Color="#FF453A" />
    <SolidColorBrush x:Key="InfoBrush" Color="#0A84FF" />
    <SolidColorBrush x:Key="MutedBrush" Color="#8E8E93" />

</ResourceDictionary>
