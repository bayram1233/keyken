<UserControl
    x:Class="FendrSystemCare.Views.CleanupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:FendrSystemCare.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:CleanupViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Style="{StaticResource FadeInUp}" Margin="4,8,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Cleanup" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Reclaim disk space by removing temporary and cache files."
                       Style="{StaticResource PageSubtitle}" />
        </StackPanel>

        <!-- Summary + actions -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Recoverable space" Style="{StaticResource MetricLabel}" />
                    <TextBlock FontSize="30" FontWeight="Bold"
                               Foreground="{StaticResource InfoBrush}"
                               Text="{Binding TotalRecoverable, Converter={StaticResource BytesToString}}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <ui:Button Content="Select all" Command="{Binding SelectAllCommand}" Margin="0,0,8,0" />
                    <ui:Button Content="Clear" Command="{Binding SelectNoneCommand}" Margin="0,0,8,0" />
                    <ui:Button Content="Scan" Icon="{ui:SymbolIcon Search24}"
                               Command="{Binding ScanCommand}" Margin="0,0,8,0" />
                    <ui:Button Content="Clean now" Appearance="Primary" Icon="{ui:SymbolIcon Broom24}"
                               Command="{Binding CleanCommand}" Margin="0,0,8,0" />
                    <ui:Button Content="Cancel" Command="{Binding CancelCommand}"
                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Categories -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Categories}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Padding="14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                                <ui:SymbolIcon Grid.Column="1" Symbol="{Binding Icon}" Margin="8,0,14,0"
                                               VerticalAlignment="Center" Foreground="{StaticResource InfoBrush}" />
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Description}" Style="{StaticResource MetricLabel}" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20"
                                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding SizeBytes, Converter={StaticResource BytesToString}}"
                                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Status -->
        <TextBlock Grid.Row="3" Margin="4,10,0,0" Style="{StaticResource MetricLabel}"
                   Text="{Binding StatusMessage}" />
    </Grid>
</UserControl>
