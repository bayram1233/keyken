<Window x:Class="FendrSystemCare.Views.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Fendr System Care — Lisans"
        Width="480" Height="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,24">
            <Border Width="56" Height="56" CornerRadius="14" HorizontalAlignment="Center"
                    Background="{StaticResource AccentGradientBrush}">
                <ui:SymbolIcon Symbol="ShieldCheckmark24" FontSize="28" Foreground="White" />
            </Border>
            <TextBlock Text="Fendr System Care" FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,12,0,4" />
            <TextBlock Text="Devam etmek için API anahtarınızı girin" FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <ui:TextBox Grid.Row="1" x:Name="KeyBox"
                    PlaceholderText="FENDR-XXXXXXXX-CCCC"
                    Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                    Icon="{ui:SymbolIcon Key24}" Margin="0,0,0,8" />

        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                   TextWrapping="Wrap" Margin="0,0,0,12" />

        <StackPanel Grid.Row="4">
            <ui:Button Content="Etkinleştir ve Başlat" Appearance="Primary"
                       HorizontalAlignment="Stretch" Padding="12,10"
                       Command="{Binding ActivateCommand}" Margin="0,0,0,8" />
            <ui:Button Content="API Anahtarı Al (Web Sitesi)" Appearance="Secondary"
                       HorizontalAlignment="Stretch" Padding="12,8"
                       Command="{Binding OpenActivationSiteCommand}" />
            <TextBlock Text="Anahtar almak için reklam izlemeniz gerekir."
                       FontSize="11" Opacity="0.7" TextAlignment="Center" Margin="0,12,0,0" />
        </StackPanel>
    </Grid>
</Window>
