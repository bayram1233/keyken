<UserControl
    x:Class="FendrSystemCare.Views.PerformancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:FendrSystemCare.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:PerformanceViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,16,16">
        <StackPanel Style="{StaticResource FadeInUp}">
            <TextBlock Text="Performance" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Live monitoring and one-click optimisation." Style="{StaticResource PageSubtitle}" />

            <!-- Live graphs -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Live Utilisation" Style="{StaticResource CardTitle}" />
                    <UniformGrid Columns="3">
                        <StackPanel Margin="6">
                            <TextBlock Text="{Binding CpuPercent, StringFormat='CPU · {0:0}%'}" FontWeight="SemiBold" />
                            <Border Height="120" Margin="0,6,0,0" ClipToBounds="True"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="8">
                                <Polyline Points="{Binding CpuPoints}" Stroke="{StaticResource InfoBrush}"
                                          StrokeThickness="2" StrokeLineJoin="Round" />
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="6">
                            <TextBlock Text="{Binding RamPercent, StringFormat='RAM · {0:0}%'}" FontWeight="SemiBold" />
                            <Border Height="120" Margin="0,6,0,0" ClipToBounds="True"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="8">
                                <Polyline Points="{Binding RamPoints}" Stroke="{StaticResource SuccessBrush}"
                                          StrokeThickness="2" StrokeLineJoin="Round" />
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="6">
                            <TextBlock Text="{Binding GpuPercent, StringFormat='GPU · {0:0}%'}" FontWeight="SemiBold" />
                            <Border Height="120" Margin="0,6,0,0" ClipToBounds="True"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="8">
                                <Polyline Points="{Binding GpuPoints}" Stroke="{StaticResource WarningBrush}"
                                          StrokeThickness="2" StrokeLineJoin="Round" />
                            </Border>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Sensors -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <UniformGrid Columns="4">
                    <StackPanel>
                        <TextBlock Text="Network" Style="{StaticResource MetricLabel}" />
                        <TextBlock Text="{Binding NetworkText}" Style="{StaticResource MetricValue}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Disk activity" Style="{StaticResource MetricLabel}" />
                        <TextBlock Text="{Binding DiskPercent, StringFormat={}{0:0}%}" Style="{StaticResource MetricValue}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Temperature" Style="{StaticResource MetricLabel}" />
                        <TextBlock Text="{Binding TemperatureText}" Style="{StaticResource MetricValue}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Fan" Style="{StaticResource MetricLabel}" />
                        <TextBlock Text="{Binding FanText}" Style="{StaticResource MetricValue}" />
                    </StackPanel>
                </UniformGrid>
            </Border>

            <!-- Optimisation actions -->
            <TextBlock Text="Optimisation" Style="{StaticResource CardTitle}" Margin="4,4,0,8" />
            <WrapPanel>
                <WrapPanel.Resources>
                    <Style TargetType="ui:Button">
                        <Setter Property="Width" Value="230" />
                        <Setter Property="Height" Value="64" />
                        <Setter Property="Margin" Value="0,0,12,12" />
                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                    </Style>
                </WrapPanel.Resources>

                <ui:Button Icon="{ui:SymbolIcon Settings24}" Content="Optimize services"
                           Command="{Binding OptimizeServicesCommand}" />
                <ui:Button Icon="{ui:SymbolIcon Eye24}" Content="Disable telemetry"
                           Command="{Binding DisableTelemetryCommand}" />
                <ui:Button Icon="{ui:SymbolIcon Apps24}" Content="Disable background apps"
                           Command="{Binding DisableBackgroundAppsCommand}" />
                <ui:Button Icon="{ui:SymbolIcon HardDrive24}" Content="Optimize drives"
                           Command="{Binding OptimizeDrivesCommand}" />
                <ui:Button Icon="{ui:SymbolIcon Games24}" Content="Gaming mode"
                           Command="{Binding GamingModeCommand}" />
                <ui:Button Icon="{ui:SymbolIcon Flash24}" Content="High performance"
                           Command="{Binding HighPerformanceCommand}" />
                <ui:Button Icon="{ui:SymbolIcon Broom24}" Content="Clean memory"
                           Command="{Binding CleanMemoryCommand}" />
            </WrapPanel>

            <TextBlock Margin="4,4,0,0" Style="{StaticResource MetricLabel}" Text="{Binding StatusMessage}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
