<UserControl
    x:Class="FendrSystemCare.Views.StartupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:FendrSystemCare.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:StartupViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Style="{StaticResource FadeInUp}" Margin="4,8,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Startup Manager" Style="{StaticResource PageTitle}" />
                <TextBlock Text="Control which apps launch when you sign in." Style="{StaticResource PageSubtitle}" />
            </StackPanel>
            <ui:Button HorizontalAlignment="Right" VerticalAlignment="Top" Content="Refresh"
                       Icon="{ui:SymbolIcon ArrowClockwise24}" Command="{Binding RefreshCommand}" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Padding="14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="10" Height="10" CornerRadius="5" Margin="0,0,14,0"
                                        VerticalAlignment="Center"
                                        Background="{Binding Impact, Converter={StaticResource ImpactToBrush}}" />

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Style="{StaticResource MetricLabel}"
                                               Text="{Binding Publisher}" />
                                    <TextBlock Style="{StaticResource MetricLabel}" Opacity="0.8"
                                               Text="{Binding Command}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <Border Grid.Column="2" VerticalAlignment="Center" Margin="0,0,10,0"
                                        CornerRadius="8" Padding="10,3"
                                        Background="{Binding Impact, Converter={StaticResource ImpactToBrush}}">
                                    <TextBlock Text="{Binding Impact}" Foreground="White" FontSize="12" />
                                </Border>

                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                    <ui:ToggleSwitch IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                     Command="{Binding DataContext.ToggleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                     CommandParameter="{Binding}" Margin="0,0,10,0" />
                                    <ui:Button Icon="{ui:SymbolIcon Clock24}" ToolTip="Delay 1 min"
                                               Command="{Binding DataContext.DelayCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                               CommandParameter="{Binding}" Margin="0,0,6,0" />
                                    <ui:Button Icon="{ui:SymbolIcon Delete24}" ToolTip="Remove"
                                               Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                               CommandParameter="{Binding}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
