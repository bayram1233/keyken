<UserControl
    x:Class="FendrSystemCare.Views.SystemRepairPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:FendrSystemCare.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:SystemRepairViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Style="{StaticResource FadeInUp}" Margin="4,8,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="System Repair" Style="{StaticResource PageTitle}" />
                <TextBlock Text="Diagnose and repair Windows with built-in tooling. A restore point is created first."
                           Style="{StaticResource PageSubtitle}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <ui:Button Content="Recommended" Command="{Binding SelectRecommendedCommand}" Margin="0,0,8,0" />
                <ui:Button Content="Run selected" Appearance="Primary" Icon="{ui:SymbolIcon Play24}"
                           Command="{Binding RunSelectedCommand}" Margin="0,0,8,0" />
                <ui:Button Content="Cancel" Command="{Binding CancelCommand}"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Task list -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0" Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Tasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="6,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                                    <ui:SymbolIcon Grid.Column="1" Symbol="{Binding Icon}" Margin="8,0,12,0"
                                                   VerticalAlignment="Center" Foreground="{StaticResource InfoBrush}" />
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource MetricLabel}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Ellipse Grid.Column="3" Width="12" Height="12" VerticalAlignment="Center"
                                             Fill="{Binding Status, Converter={StaticResource StatusToBrush}}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Console output -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="14,10"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            CornerRadius="12,12,0,0">
                        <TextBlock Text="{Binding StatusMessage, TargetNullValue='Output'}" FontWeight="SemiBold" />
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                        <ItemsControl ItemsSource="{Binding Output}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
