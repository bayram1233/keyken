<UserControl
    x:Class="FendrSystemCare.Views.ToolsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:FendrSystemCare.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:ToolsViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Style="{StaticResource FadeInUp}" Margin="4,8,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Tools" Style="{StaticResource PageTitle}" />
            <TextBlock Text="System utilities, inventory, reports and the hosts editor." Style="{StaticResource PageSubtitle}" />
        </StackPanel>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <!-- Quick tools -->
            <TabItem Header="Overview">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="System consoles" Style="{StaticResource CardTitle}" />
                        <WrapPanel>
                            <WrapPanel.Resources>
                                <Style TargetType="ui:Button">
                                    <Setter Property="Width" Value="210" />
                                    <Setter Property="Margin" Value="0,0,10,10" />
                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                </Style>
                            </WrapPanel.Resources>
                            <ui:Button Content="Device Manager" Icon="{ui:SymbolIcon DeveloperBoard24}"
                                       Command="{Binding LaunchCommand}" CommandParameter="device_manager" />
                            <ui:Button Content="Event Viewer" Icon="{ui:SymbolIcon Note24}"
                                       Command="{Binding LaunchCommand}" CommandParameter="event_viewer" />
                            <ui:Button Content="Task Scheduler" Icon="{ui:SymbolIcon Clock24}"
                                       Command="{Binding LaunchCommand}" CommandParameter="task_scheduler" />
                            <ui:Button Content="Services" Icon="{ui:SymbolIcon Settings24}"
                                       Command="{Binding LaunchCommand}" CommandParameter="services" />
                            <ui:Button Content="System Information" Icon="{ui:SymbolIcon Info24}"
                                       Command="{Binding LaunchCommand}" CommandParameter="system_info" />
                            <ui:Button Content="Disk Management" Icon="{ui:SymbolIcon HardDrive24}"
                                       Command="{Binding LaunchCommand}" CommandParameter="disk_management" />
                            <ui:Button Content="Registry Editor" Icon="{ui:SymbolIcon Database24}"
                                       Command="{Binding LaunchCommand}" CommandParameter="registry_editor" />
                            <ui:Button Content="Environment Variables" Icon="{ui:SymbolIcon Code24}"
                                       Command="{Binding LaunchCommand}" CommandParameter="environment_variables" />
                        </WrapPanel>

                        <TextBlock Text="Protection &amp; reports" Style="{StaticResource CardTitle}" Margin="0,14,0,8" />
                        <WrapPanel>
                            <WrapPanel.Resources>
                                <Style TargetType="ui:Button">
                                    <Setter Property="Width" Value="210" />
                                    <Setter Property="Margin" Value="0,0,10,10" />
                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                </Style>
                            </WrapPanel.Resources>
                            <ui:Button Content="Create restore point" Appearance="Primary" Icon="{ui:SymbolIcon History24}"
                                       Command="{Binding CreateRestorePointCommand}" />
                            <ui:Button Content="Restore point manager" Icon="{ui:SymbolIcon ArrowUndo24}"
                                       Command="{Binding OpenRestoreManagerCommand}" />
                            <ui:Button Content="Report (JSON)" Icon="{ui:SymbolIcon Document24}"
                                       Command="{Binding GenerateReportCommand}" CommandParameter="json" />
                            <ui:Button Content="Report (HTML)" Icon="{ui:SymbolIcon Globe24}"
                                       Command="{Binding GenerateReportCommand}" CommandParameter="html" />
                            <ui:Button Content="Report (PDF)" Icon="{ui:SymbolIcon DocumentPdf24}"
                                       Command="{Binding GenerateReportCommand}" CommandParameter="pdf" />
                        </WrapPanel>
                        <TextBlock Margin="0,6,0,0" Style="{StaticResource MetricLabel}" Text="{Binding StatusMessage}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Installed programs -->
            <TabItem Header="Programs">
                <DataGrid ItemsSource="{Binding Programs}" AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="None" Background="Transparent" BorderThickness="0"
                          HeadersVisibility="Column" CanUserAddRows="False" Margin="0,12,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
                        <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="*" />
                        <DataGridTextColumn Header="Publisher" Binding="{Binding Publisher}" Width="1.5*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Services -->
            <TabItem Header="Services">
                <DataGrid ItemsSource="{Binding Services}" AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="None" Background="Transparent" BorderThickness="0"
                          HeadersVisibility="Column" CanUserAddRows="False" Margin="0,12,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Display name" Binding="{Binding DisplayName}" Width="2*" />
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto" />
                        <DataGridTextColumn Header="Start type" Binding="{Binding StartType}" Width="Auto" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Network -->
            <TabItem Header="Network">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <ItemsControl Grid.Row="0" ItemsSource="{Binding Adapters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Style="{StaticResource MetricLabel}" Text="{Binding Description}" />
                                        <TextBlock Style="{StaticResource MetricLabel}"
                                                   Text="{Binding Ipv4, StringFormat='IPv4: {0}'}" />
                                        <TextBlock Style="{StaticResource MetricLabel}"
                                                   Text="{Binding MacAddress, StringFormat='MAC: {0}'}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" Margin="0,4,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                            <TextBox Text="{Binding IpConfig, Mode=OneWay}" IsReadOnly="True"
                                     FontFamily="Consolas" FontSize="12" BorderThickness="0"
                                     Background="Transparent" TextWrapping="NoWrap" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Hosts editor -->
            <TabItem Header="Hosts file">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource Card}" Padding="0">
                        <TextBox Text="{Binding HostsContent, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" AcceptsTab="True" FontFamily="Consolas"
                                 VerticalScrollBarVisibility="Auto" BorderThickness="0"
                                 Background="Transparent" Padding="12" />
                    </Border>
                    <ui:Button Grid.Row="1" Content="Save hosts file" Appearance="Primary" Margin="0,10,0,0"
                               HorizontalAlignment="Right" Icon="{ui:SymbolIcon Save24}"
                               Command="{Binding SaveHostsCommand}" />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
