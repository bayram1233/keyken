<UserControl
    x:Class="FendrSystemCare.Views.WindowsUpdatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:FendrSystemCare.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:WindowsUpdateViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Style="{StaticResource FadeInUp}" Margin="4,8,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Windows Update" Style="{StaticResource PageTitle}" />
                <TextBlock Text="Check, install, pause and review updates." Style="{StaticResource PageSubtitle}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <ui:Button Content="Check" Appearance="Primary" Icon="{ui:SymbolIcon ArrowSync24}"
                           Command="{Binding CheckCommand}" Margin="0,0,8,0" />
                <ui:Button Content="Install" Icon="{ui:SymbolIcon ArrowDownload24}"
                           Command="{Binding InstallCommand}" Margin="0,0,8,0" />
                <ui:Button Content="Pause 7d" Command="{Binding PauseCommand}" Margin="0,0,8,0" />
                <ui:Button Content="Resume" Command="{Binding ResumeCommand}" Margin="0,0,8,0" />
                <ui:Button Content="Cancel" Command="{Binding CancelCommand}"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Available updates" Style="{StaticResource CardTitle}" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Available}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Title}" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding KbArticle}" Style="{StaticResource MetricLabel}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                   Style="{StaticResource MetricLabel}"
                                                   Text="{Binding SizeMb, StringFormat='{}{0} MB'}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Update history" Style="{StaticResource CardTitle}" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding History}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Title}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                   Style="{StaticResource MetricLabel}"
                                                   Text="{Binding Date, StringFormat=yyyy-MM-dd}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" Margin="4,10,0,0" Style="{StaticResource MetricLabel}"
                   Text="{Binding StatusMessage}" />
    </Grid>
</UserControl>
